<html lang="en" class="no-js">
<head>
    <meta charset="utf-8" />

    <title>{% if meta.title %}{{ meta.title }} | {% endif %}{{ site_title }}</title>
    {% if meta.description %}
        <meta name="description" content="{{ meta.description|striptags }}">
    {% endif %}{% if meta.robots %}
        <meta name="robots" content="{{ meta.robots }}">
    {% endif %}
    <meta name="author" content="Lucas Battich">

    <link rel="stylesheet" href="{{ theme_url }}/css/bootstrap.min.css" type="text/css" />
    <link rel="stylesheet" href="{{ theme_url }}/css/style.css" type="text/css" />

    <script src="{{ theme_url }}/scripts/modernizr-2.6.1.min.js"></script>
    <script src="{{ theme_url }}/scripts/jquery-3.1.0.min.js"></script>

    {% if meta.math %}
        <script type="text/javascript" async
            src="https://cdnjs.cloudflare.com/ajax/libs/mathjax/2.7.2/MathJax.js?config=AM_CHTML">
        </script>
    {% endif %}
    
</head>
<body>
    <!-- header -->
    {% include "header.twig" %}

    <!-- Content -->
    <section id="content">
        <div class="container-fluid">
            <div class="row">
                <div class="col-md-2 hidden-sm-down">
                    {% include "portfolio-menu.twig" %}
                </div>

                <div class="col-md-10">
                    <div class="row text-center text-lg-left clearfix">
                    {% for page in pages if page.meta.images%}
                        {% if page.id starts with "portfolio/" and page.meta.images%}
                            <div class="col-lg-3 col-md-4 col-xs-6 mh-100 d-block clearfix">
                                <a href="{{ page.url }}" class="d-block m-4 p-4">
                                    {% if page.meta.images %}
                                         {% set image = page.meta.images|split(',')|first %}
                                    <img class="img-fluid img-thumbnail" src="{{ base_url }}/assets/portfolio/{{ image }}" alt="{{ page.title }}" style="object-fit: cover; overflow: hidden; height: 200px; width : 200px;">

                                    {% elseif page.meta.video %}
                                    <div class="embed-responsive embed-responsive-16by9 img-thumbnail">
                                        <iframe class="embed-responsive-item" src={{ page.meta.video }}"></iframe>
                                    </div>
                                    {% endif %}
                                </a>
                            </div>
                        {% endif %}
                    {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- footer -->
    {% include "footer.twig" %}

</body>
</html>
